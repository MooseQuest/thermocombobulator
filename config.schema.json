{
  "pluginAlias": "Thermocombobulator",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "headerDisplay": "Set up climate control for a room. Use the **Add device** buttons in the setup screen to sign in and find your thermostats, A/Cs, and purifiers — everything else just works on smart defaults.",
  "footerDisplay": "Need help? https://github.com/moosequest/thermocombobulator",
  "schema": {
    "type": "object",
    "properties": {
      "name": { "type": "string", "default": "Thermocombobulator" },
      "smartThingsToken": { "title": "SmartThings token (optional)", "type": "string" },
      "pollIntervalSeconds": { "title": "Refresh every (seconds)", "type": "integer", "default": 30, "minimum": 5 },
      "zones": {
        "type": "array",
        "title": "Rooms",
        "items": {
          "type": "object",
          "properties": {
            "name": { "title": "Room", "type": "string", "required": true, "placeholder": "e.g. Rear Bedroom" },
            "control": {
              "type": "object",
              "properties": {
                "defaultMode": { "title": "Mode", "type": "string", "default": "auto",
                  "oneOf": [
                    { "title": "Auto — let it manage heat & cool", "enum": ["auto"] },
                    { "title": "Heat only", "enum": ["heat"] },
                    { "title": "Cool only", "enum": ["cool"] },
                    { "title": "Off", "enum": ["off"] }
                  ] },
                "season": { "type": "string", "default": "auto" },
                "changeoverTempC": { "type": "number" },
                "seasonDeadbandC": { "type": "number", "default": 3 },
                "tempBandC": { "type": "number", "default": 0.5 },
                "supplementalDeltaC": { "type": "number", "default": 2 },
                "circulateFans": { "type": "boolean", "default": false },
                "freeCoolingMarginC": { "type": "number", "default": 0 },
                "humidityTarget": { "type": "number" },
                "humidityBandPct": { "type": "number", "default": 5 }
              }
            }
          }
        }
      }
    }
  },
  "layout": [
    {
      "key": "zones",
      "type": "array",
      "title": "Rooms",
      "buttonText": "Add room",
      "items": [
        "zones[].name",
        "zones[].control.defaultMode",
        {
          "type": "fieldset",
          "expandable": true,
          "expanded": false,
          "title": "Advanced (optional — smart defaults are fine)",
          "items": [
            "zones[].control.humidityTarget",
            "zones[].control.changeoverTempC",
            "zones[].control.circulateFans",
            "zones[].control.freeCoolingMarginC",
            "zones[].control.supplementalDeltaC",
            "zones[].control.tempBandC"
          ]
        }
      ]
    },
    {
      "type": "fieldset",
      "expandable": true,
      "expanded": false,
      "title": "Plugin settings (optional)",
      "items": ["smartThingsToken", "pollIntervalSeconds"]
    }
  ]
}
